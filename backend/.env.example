# --- Gmail (dùng App Password, không phải mật khẩu thường) ---
# Bật App Password: myaccount.google.com → Security → 2-Step → App passwords
GMAIL_SENDER=truongminhkhoa16@gmail.com
GMAIL_APP_PASSWORD=ilwd tdkf wceb dipq

# --- Telegram Bot ---
# Tạo bot: nhắn /newbot cho @BotFather trên Telegram
